# Get a token from https://huggingface.co/settings/tokens (read access is enough for Inference API).
# This file is loaded by Next.js as `.env.local` (copy this file and rename).

HF_TOKEN=hf_your_token_here

# Optional overrides:
# HF_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
#
# Model for /api/generate:
# - Chat / instruct models → router .../v1/chat/completions
# - google/flan-t5-* (text2text) → hf-inference text-generation (NOT chat)
# HF_GENERATE_MODEL=google/flan-t5-small
# https://huggingface.co/settings/inference-providers
