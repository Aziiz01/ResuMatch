# Get a token from https://huggingface.co/settings/tokens (read access is enough for Inference API).
# This file is loaded by Next.js as `.env.local` (copy this file and rename).

HF_TOKEN=hf_your_token_here

# Optional: pin a single embeddings model (otherwise tries BGE-large → E5-large → MPNet).
# HF_EMBEDDINGS_MODEL=BAAI/bge-large-en-v1.5

# Optional: pin a single chat model for /api/generate (otherwise tries Llama 3.1 8B → Qwen2.5 7B → Mistral 7B).
# HF_GENERATE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Gated models (e.g. Llama): open the model page on huggingface.co and accept the license first.
# Inference Providers: https://huggingface.co/settings/inference-providers
